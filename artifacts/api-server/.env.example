# Copy this file to .env and fill in your values
# NEVER commit the actual .env file

# Supabase PostgreSQL connection string
# Format: postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:6543/postgres
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:6543/postgres"

# API Server Port (optional, defaults to 3000)
PORT=3000
